# Required — Supabase project credentials
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required for AI Coach Insights (server-side only)
ANTHROPIC_API_KEY=

# Optional — read-only public demo. When true, logged-out visitors browse the
# seeded demo account (read-only via demo-public RLS) instead of being sent to
# login. Real users still log in and see their own data. Set BOTH to enable.
# NEXT_PUBLIC_DEMO_MODE=true
# NEXT_PUBLIC_DEMO_USER_ID=581543c1-a23a-4f95-a7ed-c98fb285ece7

# Optional — Fitbit connector (auto-import cardio). All server-side only.
# Register an app at https://dev.fitbit.com/apps (OAuth 2.0, scopes: activity heartrate).
# FITBIT_CLIENT_ID=
# FITBIT_CLIENT_SECRET=
# FITBIT_REDIRECT_URI=https://redjitsu.vercel.app/api/fitbit/callback
# 32-byte base64 key for encrypting Fitbit tokens at rest:  openssl rand -base64 32
# TOKEN_ENC_KEY=
# Service role key (used ONLY by the daily Fitbit sync cron — never client-exposed):
# SUPABASE_SERVICE_ROLE_KEY=
# Secret that authorizes the Vercel Cron call:  openssl rand -hex 32
# CRON_SECRET=

# Optional — Splunk HEC logging for /api/log
# SPLUNK_URL=
# SPLUNK_HEC_TOKEN=
# Dev only: allow self-signed Splunk certs
# SPLUNK_ALLOW_SELF_SIGNED=false
